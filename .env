# Raspberry Pi kiosk image provisioning settings
# Copy this file to .env and edit.

# Raspberry Pi OS image URL
IMG_URL=https://downloads.raspberrypi.org/raspios_lite_armhf_latest

# Working directory on host for temporary files
WORK_DIR=/tmp/pi-kiosk-setup

# Mount points on host for the image's partitions
ROOT_MOUNT=/mnt/rpi-root
BOOT_MOUNT=/mnt/rpi-boot

# Whether to ask interactively before wiping the target device
# true  = ask for "YES"
# false = no interactive prompt
CONFIRM_ERASE=true

# Enable Wi-Fi configuration on first boot
WIFI_ENABLE=true
WIFI_COUNTRY=GB
WIFI_SSID=YourWifiName
WIFI_PSK=YourWifiPassword

# Enable SSH on first boot by creating an 'ssh' flag file on /boot
ENABLE_SSH=true

